{
  "C_Cpp.default.configurationProvider": "",
  "C_Cpp.default.intelliSenseMode": "windows-clang-arm",
  "C_Cpp.default.cStandard": "c99",
  "C_Cpp.default.cppStandard": "c++11",
  "C_Cpp.errorSquiggles": "disabled",
  "C_Cpp.configurationWarnings": "disabled",
  
  // IMPORTANT: Users must configure these paths for their local machine
  // Install ARMCC6 (Keil MDK) and set the installation directory below
  "EIDE.ARM.ARMCC6.InstallDirectory": "C:/Keil_v5/ARM/ARMCLANG",
  
  // Install OpenOCD and set the executable path below
  "EIDE.OpenOCD.ExePath": "C:/openocd/bin/openocd.exe",
  
  "terminal.integrated.env.windows": {
    "PATH": "C:/Keil_v5/ARM/ARMCLANG/bin;${env:PATH}"
  },
  "C_Cpp_Runner.cCompilerPath": "C:/Keil_v5/ARM/ARMCLANG/bin/armclang.exe",
  "C_Cpp_Runner.cppCompilerPath": "C:/Keil_v5/ARM/ARMCLANG/bin/armclang.exe",
  "C_Cpp_Runner.debuggerPath": "gdb",
  "C_Cpp_Runner.cStandard": "c99",
  "C_Cpp_Runner.cppStandard": "c++11",
  "C_Cpp_Runner.useMsvc": false,
  "C_Cpp_Runner.warnings": [
    "-Wall",
    "-Wextra",
    "-Wpedantic"
  ],
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [],
  "C_Cpp_Runner.linkerArgs": [],
  "C_Cpp_Runner.includePaths": [],
  "C_Cpp_Runner.includeSearch": [
    "*",
    "**/*"
  ],
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/.vscode/**"
  ],
  "C_Cpp_Runner.useAddressSanitizer": false,
  "C_Cpp_Runner.useUndefinedSanitizer": false,
  "C_Cpp_Runner.useLeakSanitizer": false,
  "C_Cpp_Runner.showCompilationTime": false,
  "C_Cpp_Runner.useLinkTimeOptimization": false
}
