{
  "controller": "visual_servo_delta_steps",
  "command_type": "MotorCommand",
  "error_input": "target_screen_point_minus_red_laser_screen_point",
  "gains": {
    "yaw_kp_steps_per_mm": 1.0,
    "yaw_kd_steps_per_mm_per_frame": 0.0,
    "pitch_kp_steps_per_mm": 1.0,
    "pitch_kd_steps_per_mm_per_frame": 0.0
  },
  "limits": {
    "deadband_mm": 3,
    "max_yaw_delta_steps_per_frame": 80,
    "max_pitch_delta_steps_per_frame": 80,
    "max_speed_steps_per_s": 1200
  },
  "safety": {
    "pause_on_detection_loss": true,
    "pause_on_out_of_screen": true
  }
}
